# .env.example
# --- API CONFIGURATION ---
API_KEY=your_api_key_here

# --- DATABASE CONFIGURATION ---
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
# Note: Host should be 'postgres' (your docker service name)
DATABASE_URL=postgresql://user:password@postgres:5432/cars_db

# --- DOCKER POSTGRES CONFIG (Matches docker-compose.yml) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=